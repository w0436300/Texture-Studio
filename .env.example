# Google Gemini API key used by /api/generate
# Create a key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Model id for image generation. Optional, defaults to the model below.
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Set to "1" to force the mock renderer even when an API key is present.
TEXTURE_STUDIO_MOCK=0
